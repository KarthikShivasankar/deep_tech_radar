# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real tokens.

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Write token (Settings → Access Tokens → New token → Role: write)
HF_TOKEN=hf_your_write_token_here

# Your HF username or organisation name (the dataset owner)
HF_USERNAME=your-hf-username-or-org

# Dataset repo name (created automatically on first submit)
DATASET_NAME=deep-tech-radar

# ── Semantic Scholar (optional) ───────────────────────────────────────────────
# Without a key you get ~100 requests/5 min.
# Request a free key at https://www.semanticscholar.org/product/api
SS_API_KEY=

# ── Ollama / AI Agents ────────────────────────────────────────────────────────
# Start Ollama: ollama serve
# Pull model:   ollama pull gemma3   (or gemma4 if available: ollama list)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma3:latest
